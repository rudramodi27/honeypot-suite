# /etc/honeypot-suite/dashboard.env
# Mode 0600, owned by root:honeypot (readable by the honeypot group
# systemd uses to launch the service, not world-readable).
#
#   sudo install -o root -g honeypot -m 0640 deploy/systemd/honeypot-dashboard.env.example \
#        /etc/honeypot-suite/dashboard.env
#   sudo $EDITOR /etc/honeypot-suite/dashboard.env   # fill in real values
#
# Prefer populating this file FROM Vault at deploy time rather than
# editing by hand — see hardening/vault_commands.sh for the
# `vault kv get` → template → write pattern.

HONEYPOT__DASHBOARD__SECRET_KEY=__REPLACE_WITH_RANDOM_32_BYTE_HEX__
HONEYPOT__DASHBOARD__PASSWORD_HASH=__REPLACE_WITH_WERKZEUG_HASH__
HONEYPOT__THREAT_INTEL__ABUSEIPDB__API_KEY=__REPLACE_OR_LEAVE_BLANK__
HONEYPOT__THREAT_INTEL__VIRUSTOTAL__API_KEY=__REPLACE_OR_LEAVE_BLANK__

# =====================================================================
# Advanced Honeypot Suite — Environment Variables
# Copy this file to `.env` and fill in real values before deploying.
# docker-compose.yml reads these automatically.
# NEVER commit your actual .env file to version control.
# =====================================================================

# ── Dashboard secrets ─────────────────────────────────────────
# Generate a real secret: python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_SECRET_KEY=CHANGE_ME_RANDOM_32_BYTE_HEX_STRING

# Generate a password hash:
#   python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('yourpassword'))"
DASHBOARD_PASSWORD_HASH=

# ── Threat intel API keys (all optional — leave blank to skip) ──
# AbuseIPDB: https://www.abuseipdb.com/account/api  (free tier: 1000 req/day)
ABUSEIPDB_KEY=

# VirusTotal: https://www.virustotal.com/gui/my-apikey  (free tier: 4 req/min)
VT_KEY=

# Shodan: https://account.shodan.io/  (optional, for passive recon context)
SHODAN_KEY=

# ── Alerting (optional) ──────────────────────────────────────────
SMTP_USERNAME=
SMTP_PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
